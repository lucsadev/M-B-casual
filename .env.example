# ============================================================
# M&B Trend — Supabase Database Configuration
# ============================================================
# Copiá este archivo a .env y completá los valores.
# NUNCA comitees el .env con contraseñas reales.
#
# Para obtener estos datos:
# 1. Andá a https://supabase.com/dashboard
# 2. Seleccioná tu proyecto
# 3. Project Settings → Database → Connection string
# ============================================================

# Host de la base de datos (formato: db.xxxxx.supabase.co)
SUPABASE_DB_HOST=db.ruiktuqujhjhubtkguuc.supabase.co

# Puerto (5432 para directo, 6543 para pooler)
# SUPABASE_DB_PORT=5432

# Nombre de la base de datos (default: postgres)
# SUPABASE_DB_NAME=postgres

# Usuario (default: postgres)
# SUPABASE_DB_USER=postgres

# ⚠️ CONTRASEÑA — Reemplazá con la tuya
# La encontrás en: Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=tu_contraseña_aqui

# ============================================================
# Opcional: Configuración de la app web
# ============================================================
# VITE_SUPABASE_URL=https://ruiktuqujhjhubtkguuc.supabase.co
# VITE_SUPABASE_ANON_KEY=tu_anon_key
