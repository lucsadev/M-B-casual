{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "paths": {
      "@/*": ["./src/*"],
      "@mbt/shared": ["../shared/src"]
    }
  },
  "include": [
    "src",
    "*.ts",
    "*.tsx"
  ]
}
